<!DOCTYPE html<html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>WhatsApp Sistema</title><style>*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif}body{background:#f0f2f5;height:100vh;display:flex;align-items:center;justify-content:center}.login-box{background:white;padding:40px;border-radius:12px;width:360px;box-shadow:0 2px 20px rgba(0,0,0,0.1)}.login-box h2{color:#075e54;margin-bottom:24px;text-align:center}.login-box input{width:100%;padding:12px;margin-bottom:12px;border:1px solid #ddd;border-radius:8px;font-size:14px}.login-box button{width:100%;padding:12px;background:#075e54;color:white;border:none;border-radius:8px;font-size:16px;cursor:pointer}.login-box button:hover{background:#128c7e}.app{display:none;height:100vh;width:100vw;flex-direction:row}.sidebar{width:320px;background:white;border-right:1px solid #e0e0e0;display:flex;flex-direction:column}.sidebar-header{background:#075e54;color:white;padding:16px;font-size:18px;font-weight:bold}.sidebar-user{padding:12px 16px;background:#f0f2f5;font-size:13px;color:#666;border-bottom:1px solid #e0e0e0}.search-box{padding:8px;background:#f0f2f5}.search-box input{width:100%;padding:8px 12px;border:none;border-radius:20px;background:white;font-size:14px}.chat-list{flex:1;overflow-y:auto}.chat-item{padding:12px 16px;border-bottom:1px solid #f0f2f5;cursor:pointer;display:flex;align-items:center;gap:12px}.chat-item:hover{background:#f5f5f5}.chat-item.active{background:#e8f5e9}.chat-avatar{width:44px;height:44px;border-radius:50%;background:#075e54;display:flex;align-items:center;justify-content:center;color:white;font-size:18px;flex-shrink:0}.chat-info{flex:1;min-width:0}.chat-name{font-size:15px;font-weight:500;color:#111}.chat-preview{font-size:13px;color:#667781;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.badge{background:#25d366;color:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}.main{flex:1;display:flex;flex-direction:column;background:#e5ddd5}.chat-header{background:#075e54;color:white;padding:12px 16px;display:flex;align-items:center;gap:12px}.chat-header-avatar{width:40px;height:40px;border-radius:50%;background:#128c7e;display:flex;align-items:center;justify-content:center;font-size:16px}.chat-header-info h3{font-size:16px}.chat-header-info p{font-size:13px;opacity:0.8}.messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:8px}.msg{max-width:65%;padding:8px 12px;border-radius:8px;font-size:14px;line-height:1.5;position:relative}.msg.entrante{background:white;align-self:flex-start;border-radius:0 8px 8px 8px}.msg.saliente{background:#d9fdd3;align-self:flex-end;border-radius:8px 0 8px 8px}.msg-time{font-size:11px;color:#999;margin-top:4px;text-align:right}.msg-contact{font-size:11px;color:#075e54;margin-bottom:2px;font-weight:bold}.input-area{background:white;padding:12px 16px;display:flex;gap:8px;align-items:center}.input-area input{flex:1;padding:10px 16px;border:none;border-radius:24px;background:#f0f2f5;font-size:14px;outline:none}.input-area button{background:#075e54;color:white;border:none;border-radius:50%;width:44px;height:44px;cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center}.empty-state{flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;color:#667781}.empty-state p{font-size:16px}.metrics-bar{background:#128c7e;color:white;padding:8px 16px;display:flex;gap:24px;font-  <input type="email" id="email" placeholder="Correo electrónico">  <input type="password" id="pass" placeholder="Contraseña">  <button onclick="login()">Entrar</button>  <p id="loginError" style="color:red;font-size:13px;margin-top:8px;text-align:center"></p></div><div class="app" id="app">  <div class="sidebar">    <div class="sidebar-header">💬 WhatsApp Sistema</div>    <div class="sidebar-user" id="userInfo"></div>    <div class="metrics-bar" id="metricsBar"></div>    <div class="search-box"><input type="text" placeholder="Buscar conversación..." oninput="filtrarChats(this.value)"></div>    <div class="chat-list" id="chatList"></div>  </div>  <div id="mainArea" class="no-chat">    <p style="font-size:48px">💬</p>    <p>Selecciona una conversación</p>  </div></div><script>const API = '';let token = '', usuario = {}, mensajes = [], chatActivo = null, intervalo = null;async function login() {  const email = document.getElementById('email').value;  const pass = document.getElementById('pass').value;  const r = await fetch(API+'/api/login', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({email, password: pass})});  const d = await r.json();  if (d.token) {    token = d.token; usuario = d.usuario;    document.getElementById('loginBox').style.display = 'none';    document.getElementById('app').style.display = 'flex';    document.getElementById('userInfo').innerHTML = `👤 ${usuario.nombre} — ${usuario.sucursal || 'Supervisor'} <a href="#" onclick="logout()" style="float:right;color:#075e54">Salir</a>`;    cargarMensajes();    intervalo = setInterval(cargarMensajes, 5000);  } else {    document.getElementById('loginError').textContent = d.error || 'Error al iniciar sesión';  }}function logout() { clearInterval(intervalo); token=''; location.reload(); }async function cargarMensajes() {  const r = await fetch(API+'/api/mensajes', {headers:{Authorization:'Bearer '+token}});  mensajes = await r.json();  renderChats();  cargarMetricas();  if (chatActivo) renderMensajes(chatActivo);}async function cargarMetricas() {  const r = await fetch(API+'/api/metricas', {headers:{Authorization:'Bearer '+token}});  const m = await r.json();  document.getElementById('metricsBar').innerHTML = `    <div class="metric"><span>${m.total||0}</span><span>Total</span></div>    <div class="metric"><span>${m.entrantes||0}</span><span>Recibidos</span></div>    <div class="metric"><span>${m.salientes||0}</span><span>Enviados</span></div>    <div class="metric"><span style="color:#ffeb3b">${m.no_leidos||0}</span><span>Sin leer</span></div>`;}function renderChats() {  const contactos = {};  mensajes.forEach(m => {    if (!contactos[m.contacto]) contactos[m.contacto] = {ultimo: m, count: 0};    if (!m.leido && m.direccion === 'entrante') contactos[m.contacto].count++;    if (new Date(m.timestamp) > new Date(contactos[m.contacto].ultimo.timestamp)) contactos[m.contacto].ultimo = m;  });  const lista = Object.entries(contactos).sort((a,b) => new Date(b[1].ultimo.timestamp) - new Date(a[1].ultimo.timestamp));  const html = lista.map(([tel, data]) => `    <div class="chat-item ${chatActivo===tel?'active':''}" onclick="abrirChat('${tel}')">      <div class="chat-avatar">${te
